# Copy to .env.local and fill in. Mock mode (the default) needs none of this.
# .env* is gitignored — never commit real keys.

DIAGNOSIS_MODE=mock          # mock | llm — llm turns on BOTH LLM diagnosis and live LLM review-tagging

# Real LLM mode: set DIAGNOSIS_MODE=llm and set a key. Anthropic is the default provider;
# the runtime falls back anthropic → openai → rule-based, so set ANTHROPIC_API_KEY as primary
# and (optionally) OPENAI_API_KEY as the fallback.
LLM_PROVIDER=anthropic       # anthropic | openai | gemini (which provider is tried FIRST)

ANTHROPIC_API_KEY=           # primary (default provider)
OPENAI_API_KEY=              # optional fallback when anthropic fails / has no key
GEMINI_API_KEY=              # only used when LLM_PROVIDER=gemini (diagnosis only, no tag backend)

# Optional:
LLM_MODEL=                   # override the SELECTED provider's model (anthropic: claude-haiku-4-5-20251001 · openai: gpt-4o-mini · gemini: gemini-2.0-flash); fallback providers always use their own default
CONFIDENCE_THRESHOLD=0.7     # below this, cases route to a human
MIN_REVIEWS=5                # below this, diagnosis refuses to guess
RATING_FLAG_THRESHOLD=3.5    # screening rule for the bottom cohort

# Langfuse observability (OFF by default — see docs/langfuse.md).
# Leave these unset and nothing changes: no telemetry loads, mock mode + evals stay offline/free.
# Set all three (+ DIAGNOSIS_MODE=llm) and every diagnosis AND every live tag-review run becomes
# a durable trace with token counts, exact USD cost, and the guardrail/gate flags as metadata.
LANGFUSE_PUBLIC_KEY=         # pk-lf-...
LANGFUSE_SECRET_KEY=         # sk-lf-...
LANGFUSE_BASE_URL=           # https://us.cloud.langfuse.com for the US region; leave blank for EU
